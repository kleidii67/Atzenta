# Copy to .env and fill in. NEVER commit your real .env (see .gitignore).

# ---- Safety switch -----------------------------------------------------
# Leave false to run in paper/dry-run mode (no real orders, no funds risked).
# Set to true ONLY when you understand the code and accept the risk.
LIVE_TRADING=false

# ---- Credentials (required when LIVE_TRADING=true) ---------------------
# Private key of the wallet authorized to trade on Polymarket.
POLY_PRIVATE_KEY=
# Optional API creds. If omitted, they are derived from the private key.
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
# Proxy/funder wallet that holds USDC (for email/magic accounts).
POLY_FUNDER=
# 0 = EOA wallet, 1 = email/magic proxy, 2 = browser proxy.
POLY_SIGNATURE_TYPE=0

# ---- Market selection --------------------------------------------------
MARKET_QUERY=bitcoin up or down
MAX_MARKETS=20
MARKET_REFRESH_SECS=60

# ---- Strategy ----------------------------------------------------------
# Minimum guaranteed edge per share-pair, in dollars (0.01 = 1 cent).
MIN_EDGE=0.01
ORDER_SIZE=5
MAX_SIZE_PER_LEVEL=50
TAKER_FEE=0.0

# ---- Risk limits -------------------------------------------------------
MAX_TOTAL_EXPOSURE=200
MAX_TRADES=0

# ---- Misc --------------------------------------------------------------
LOG_LEVEL=INFO
